          "combinator": "and",
          "conditions": [
            {
              "operator": {
                "type": "boolean",
                "operation": "equal"
              },
              "leftValue": "={{ $json.is_negative }}",
              "rightValue": true
            }
          ]
        }
      },
      "typeVersion": 2
    },
    {
