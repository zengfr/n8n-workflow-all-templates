      ],
      "parameters": {
        "width": 400,
        "height": 240,
        "content": "## A. Sticky: “Workflow entry & user validation”\n\nThis section listens for incoming Telegram messages and validates the sender.\n\nOnly authorized user IDs are allowed to continue. Unauthorized messages are ignored to protect private interactions with the assistant."
      },
      "typeVersion": 1
