    {
      "id": "aa7080f8-4aae-4f67-ba08-562f3d7e4180",
      "name": "Route by Job Type",
      "type": "n8n-nodes-base.switch",
      "position": [
        320,
        608
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "E-commerce",
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "typeValidation": "strict"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "leftValue": "={{ $json.body.jobType.toLowerCase() }}",
                    "rightValue": "ecommerce"
                  }
                ]
              },
              "renameOutput": true
            },
            {
              "outputKey": "Remix",
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "typeValidation": "strict"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "leftValue": "={{ $json.body.jobType.toLowerCase() }}",
                    "rightValue": "remix"
                  }
                ]
              },
              "renameOutput": true
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "typeVersion": 3
    },
    {
      "id": "a66d6c39-f952-4303-b966-a7e7627e4a97",
      "name": "Respond – Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [
