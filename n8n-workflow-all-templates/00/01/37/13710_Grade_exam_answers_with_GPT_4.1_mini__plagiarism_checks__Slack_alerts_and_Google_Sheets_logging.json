      ],
      "parameters": {
        "color": 7,
        "width": 576,
        "height": 752,
        "content": "\n## Quality Moderator Agent\n**What** â€“ Reviews marking quality and routes borderline cases for secondary marking.\n**Why** â€“ Maintains assessment reliability and flags inconsistent or marginal scores."
      },
      "typeVersion": 1
    },
    {
      "id": "db18a757-5be1-414f-a9bf-02e6ee04f7c1",
