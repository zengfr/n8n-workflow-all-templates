      "position": [
        -1312,
        1056
      ],
      "parameters": {
        "color": 7,
        "width": 896,
        "height": 848,
        "content": "## Trigger, Data Retrieval & Rubric Interpretation\n**What** â€“ On manual trigger, fetches student answers and rubrics \n**Why** â€“ Ensures marking begins with complete, validated inputs and applies consistent "
      },
      "typeVersion": 1
    },
    {
      "id": "137c7cca-ccd0-4dc8-b812-8c8ffdd3586a",
      "name": "Sticky Note6",
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        544,
