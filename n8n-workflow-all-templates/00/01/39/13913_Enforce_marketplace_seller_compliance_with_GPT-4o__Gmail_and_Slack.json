      "parameters": {
        "autoFix": true,
        "schemaType": "manual",
        "inputSchema": "{\n\t\"type\": \"object\",\n\t\"properties\": {\n\t\t\"seller_id\": {\n\t\t\t\"type\": \"string\"\n\t\t},\n\t\t\"violation_type\": {\n\t\t\t\"type\": \"string\"\n\t\t},\n\t\t\"severity\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"enum\": [\"low\", \"medium\", \"high\", \"critical\"]\n\t\t},\n\t\t\"enforcement_action\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"enum\": [\"warning\", \"review\", \"suspension\", \"termination\", \"appeal_approved\", \"appeal_denied\"]\n\t\t},\n\t\t\"reasoning\": {\n\t\t\t\"type\": \"string\"\n\t\t},\n\t\t\"evidence\": {\n\t\t\t\"type\": \"array\",\n\t\t\t\"items\": {\n\t\t\t\t\"type\": \"string\"\n\t\t\t}\n\t\t},\n\t\t\"requires_human_review\": {\n\t\t\t\"type\": \"boolean\"\n\t\t},\n\t\t\"timestamp\": {\n\t\t\t\"type\": \"string\"\n\t\t}\n\t},\n\t\"required\": [\"seller_id\", \"violation_type\", \"severity\", \"enforcement_action\", \"reasoning\", \"requires_human_review\"]\n}"
