        "options": {},
        "jsonBody": "={\n  \"personTitles\": {{ JSON.stringify($json.jobTitles.split(',').map(t => t.trim())) }},\n  \"companyIndustry\": \"{{ $json.industry }}\",\n  \"companySize\": \"{{ $json.companySize }}\",\n  \"count\": {{ $json.leadCount }},\n  \"fileName\": \"{{ $json.exportFileName }}\"\n}",
