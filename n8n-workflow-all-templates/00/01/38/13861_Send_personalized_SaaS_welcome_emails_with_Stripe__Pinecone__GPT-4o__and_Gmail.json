        128
      ],
      "parameters": {
        "jsCode": "const amountInPence = $input.first().json.data.object.amount_total;\nconst amount = amountInPence / 100;\nreturn [{ json: { amount: `$${amount}` } }];"
      },
      "typeVersion": 2
