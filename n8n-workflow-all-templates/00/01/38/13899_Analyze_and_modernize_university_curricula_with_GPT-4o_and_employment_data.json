ion\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"compliance_status\": {\"type\": \"string\"},\n        \"supporting_evidence\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n        \"documentation_summary\": {\"type\": \"string\"}\n      }\n    }\n  },\n  \"required\": [\"executive_summary\", \"learning_outcome_analysis\", \"industry_demand_analysis\", \"integrated_recommendations\"]\n}"
