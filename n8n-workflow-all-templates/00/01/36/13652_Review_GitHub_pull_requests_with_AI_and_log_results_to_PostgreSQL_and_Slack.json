    {
      "id": "d64976ed-b757-422c-a53c-6f7a80d7caa9",
      "name": "Log Review Completion",
      "type": "n8n-nodes-base.code",
      "position": [
        704,
        448
      ],
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const review = $input.item.json;\nconst timestamp = new Date().toISOString();\n\nconsole.log(`✅ CODE REVIEW COMPLETED | PR #${review.prNumber} | Author: ${review.prAuthor} | Score: ${review.reviewScore}/100`);\n\nreturn {\n  json: {\n    success: true,\n    reviewId: review.reviewId,\n    prNumber: review.prNumber,\n    reviewScore: review.reviewScore,\n    timestamp\n  }\n};"
      },
      "typeVersion": 2
