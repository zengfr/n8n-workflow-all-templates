    {
      "id": "baca2d5e-6ee7-46d0-bd11-4e1f4d84e8de",
      "name": "Route by Risk Level",
      "type": "n8n-nodes-base.switch",
      "position": [
        192,
        736
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "HIGH_RISK",
              "conditions": {
                "options": {
                  "leftValue": "",
                  "caseSensitive": true,
                  "typeValidation": "strict"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "operator": {
                      "type": "number",
                      "operation": "gte"
                    },
                    "leftValue": "={{ $json.riskScore }}",
                    "rightValue": "={{ $('Workflow Configuration').first().json.riskThresholdHigh }}"
                  }
                ]
              },
              "renameOutput": true
            },
            {
              "outputKey": "CRITICAL_RISK",
              "conditions": {
                "options": {
                  "leftValue": "",
                  "caseSensitive": true,
                  "typeValidation": "strict"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "operator": {
                      "type": "number",
                      "operation": "gte"
                    },
                    "leftValue": "={{ $json.riskScore }}",
                    "rightValue": "={{ $('Workflow Configuration').first().json.riskThresholdCritical }}"
                  }
                ]
              },
              "renameOutput": true
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra",
          "renameFallbackOutput": "LOW_MEDIUM_RISK"
        }
      },
      "typeVersion": 3.4
    },
