        -912,
        576
      ],
      "parameters": {
        "text": "={{ $fromAI(\"policyAnalysis\", \"Policy interpretation results including scope, provisions, and risk level\", \"json\") }}",
        "options": {
          "systemMessage": "You are an Impact Assessment Specialist evaluating organizational impact of policy changes.\n\nYour task is to:\n1. Analyze which business areas are affected (Operations, Finance, HR, IT, Legal, etc.)\n2. Estimate implementation costs and resource requirements\n3. Determine realistic implementation timeline\n4. Identify business risks and operational challenges\n5. Recommend mitigation strategies\n6. Calculate priority score (0-100) based on urgency, impact, and risk\n7. Provide detailed reasoning for your assessment\n\nConsider: compliance deadlines, operational disruption, financial impact, and resource availability."
        },
        "hasOutputParser": true,
        "toolDescription": "Analyzes organizational impact of policy changes and provides implementation assessment including costs, timeline, and risks"
      },
      "typeVersion": 3
    },
